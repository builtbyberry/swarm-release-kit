{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "chmod +x \"${CLAUDE_PLUGIN_ROOT}/scripts/session-start.sh\" && \"${CLAUDE_PLUGIN_ROOT}/scripts/session-start.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
